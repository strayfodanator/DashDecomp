{
  "$schema": "https://raw.githubusercontent.com/encounter/objdiff/main/config.schema.json",
  "min_version": "2.0.0",
  "custom_make": "make",
  "target_dir": "build/asm",
  "base_dir": "build/base",
  "build_target": false,
  "build_base": false,
  "watch_patterns": [
    "src/**/*.cpp",
    "src/**/*.c",
    "include/**/*.h",
    "asm/**/*.s"
  ]
}
